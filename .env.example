# ── Airtable ──────────────────────────────────────────────
AIRTABLE_TOKEN=pat...
AIRTABLE_BASE_ID=app...

# ── Airtable Sync Logs (optional — logging disabled if not set) ──
AIRTABLE_LOG_BASE_ID=app...
AIRTABLE_LOG_TOKEN=pat...           # Optional — falls back to AIRTABLE_TOKEN

# ── Airtable Test Base (optional — for safe P→A testing) ──
AIRTABLE_TEST_BASE_ID=app...
AIRTABLE_TEST_TOKEN=pat...          # Optional — falls back to AIRTABLE_TOKEN

# ── Priority ERP ──────────────────────────────────────────
PRIORITY_API_URL=https://us.priority-connect.online/odata/Priority/tabc8cae.ini/{company}/
PRIORITY_USER=
PRIORITY_PASS=

# ── Priority Environments (optional — for --priority-env flag) ──
PRIORITY_SANDBOX_COMPANY=a071024
PRIORITY_UAT_COMPANY=a012226
PRIORITY_PROD_COMPANY=              # Fill in when ready

# ── Webhook (required for server mode) ────────────────────
WEBHOOK_API_KEY=
